# Environment Configuration for Talk to Data Service
# Copy this file to .env and fill in your values

# LLM Provider Configuration
# Supported providers: openai, anthropic, azure, google
LLM_PROVIDER=openai

# API Key for the LLM provider
LLM_API_KEY=your-api-key-here

# Model to use (examples: gpt-4o, claude-3-opus-20240229, gemini-1.5-flash)
LLM_MODEL=gpt-4o

# Differential Privacy Configuration
EPSILON_TOTAL=1.0
EPSILON_BASE=0.1
MIN_GROUP_SIZE=5

# Response generation LLM overrides (optional)
# If not set, the main LLM_* values are used for response generation.
# RESPONSE_LLM_PROVIDER=openai
# RESPONSE_LLM_MODEL=gpt-4o
